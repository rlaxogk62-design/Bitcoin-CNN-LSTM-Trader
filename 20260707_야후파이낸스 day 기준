ython3.12/dist-packages (from requests->pyupbit) (3.4.7)\n","Requirement already satisfied: idna<4,>=2.5 in /usr/local/lib/python3.12/dist-packages (from requests->pyupbit) (3.18)\n","Requirement already satisfied: urllib3<3,>=1.21.1 in /usr/local/lib/python3.12/dist-packages (from requests->pyupbit) (2.5.0)\n","Requirement already satisfied: pycparser in /usr/local/lib/python3.12/dist-packages (from cffi>=2.0.0->curl_cffi>=0.7->yfinance) (3.0)\n","Requirement already satisfied: six>=1.5 in /usr/local/lib/python3.12/dist-packages (from python-dateutil>=2.8.2->pandas->pyupbit) (1.17.0)\n","Requirement already satisfied: markdown-it-py>=2.2.0 in /usr/local/lib/python3.12/dist-packages (from rich->curl_cffi>=0.7->yfinance) (4.2.0)\n","Requirement already satisfied: pygments<3.0.0,>=2.13.0 in /usr/local/lib/python3.12/dist-packages (from rich->curl_cffi>=0.7->yfinance) (2.20.0)\n","Requirement already satisfied: mdurl~=0.1 in /usr/local/lib/python3.12/dist-packages (from markdown-it-py>=2.2.0->rich->curl_cffi>=0.7->yfinance) (0.1.2)\n","Downloading pyupbit-0.2.34-py3-none-any.whl (24 kB)\n","Installing collected packages: pyupbit\n","Successfully installed pyupbit-0.2.34\n"]}]},{"cell_type":"code","source":["# !pip install yfinance\n","\n","import os\n","import yfinance as yf\n","import requests\n","import pandas as pd\n","import numpy as np\n","import matplotlib.pyplot as plt\n","import joblib\n","from sklearn.preprocessing import StandardScaler\n","from keras.models import Sequential\n","from keras.layers import Conv1D, MaxPooling1D, LSTM, Dense, Dropout\n","from keras.callbacks import EarlyStopping, ModelCheckpoint, ReduceLROnPlateau\n","from keras.optimizers import Adam\n","\n","os.makedirs('./data/model/', exist_ok=True)\n","\n","# ==========================================\n","# 1. 실시간 데이터 수집 (All yfinance + FNG)\n","# ==========================================\n","def fetch_realtime_data():\n","    print(\">>> 1. 글로벌 평균 비트코인 가격 수집 중 (yfinance)...\")\n","\n","    # yf.download 대신 yf.Ticker 사용으로 구조 변경 오류 완벽 방지\n","    btc_df = yf.Ticker('BTC-USD').history(period=\"3y\")\n","    btc_df = btc_df[['Close']].rename(columns={'Close': 'BTC_Price'})\n","    btc_df.index = btc_df.index.tz_localize(None).date\n","\n","    # 타겟 및 RSI 지표 생성\n","    btc_df['BTC_Return'] = btc_df['BTC_Price'].pct_change() * 100\n","    delta = btc_df['BTC_Price'].diff()\n","    gain = (delta.where(delta > 0, 0)).rolling(window=14).mean()\n","    loss = (-delta.where(delta < 0, 0)).rolling(window=14).mean()\n","    rs = gain / loss\n","    btc_df['RSI_14d'] = 100 - (100 / (1 + rs))\n","\n","    print(\">>> 2. 매크로 지표(나스닥, 원/달러 환율) 수집 중...\")\n","    nasdaq_df = yf.Ticker('^IXIC').history(period=\"3y\")\n","    nasdaq_df = nasdaq_df[['Close']].rename(columns={'Close': 'NASDAQ'})\n","    nasdaq_df.index = nasdaq_df.index.tz_localize(None).date\n","\n","    krw_df = yf.Ticker('KRW=X').history(period=\"3y\")\n","    krw_df = krw_df[['Close']].rename(columns={'Close': 'Exchange_Rate'})\n","    krw_df.index = krw_df.index.tz_localize(None).date\n","    macro_df = pd.concat([nasdaq_df, krw_df], axis=1)\n","\n","    print(\">>> 3. 실시간 투자 심리 지표(FNG) 수집 중...\")\n","    fng_url = \"https://api.alternative.me/fng/?limit=0\"\n","    response = requests.get(fng_url)\n","    fng_data = response.json()['data']\n","\n","    df_fng = pd.DataFrame(fng_data)\n","    df_fng['value'] = df_fng['value'].astype(float)\n","    # Pandas 업데이트 경고 방지를 위해 float로 사전 변환\n","    df_fng['timestamp'] = df_fng['timestamp'].astype(float)\n","    df_fng['date'] = pd.to_datetime(df_fng['timestamp'], unit='s').dt.tz_localize('UTC').dt.tz_convert('Asia/Seoul').dt.date\n","    df_fng = df_fng.set_index('date')[['value']]\n","    df_fng.columns = ['Sentiment_Score']\n","\n","    print(\">>> 4. 데이터 병합 중...\")\n","    final_df = pd.concat([btc_df, macro_df, df_fng], axis=1).dropna()\n","    return final_df\n","\n","df = fetch_realtime_data()\n","print(f\"총 확보된 데이터 일수: {len(df)}일\\n\")\n","\n","# ==========================================\n","# 2. 데이터 전처리 및 스케일링\n","# ==========================================\n","target_col = 'BTC_Return'\n","feature_cols = ['BTC_Return', 'NASDAQ', 'Exchange_Rate', 'RSI_14d', 'Sentiment_Score']\n","\n","X_scaler = StandardScaler()\n","y_scaler = StandardScaler()\n","\n","scaled_X_data = X_scaler.fit_transform(df[feature_cols])\n","scaled_y_data = y_scaler.fit_transform(df[[target_col]])\n","\n","joblib.dump(X_scaler, './data/model/X_scaler.pkl')\n","joblib.dump(y_scaler, './data/model/y_scaler.pkl')\n","\n","# ==========================================\n","# 3. 슬라이딩 윈도우 변환 (7일 단위)\n","# ==========================================\n","window_size = 7\n","X, y = [], []\n","\n","for i in range(len(scaled_X_data) - window_size):\n","    X.append(scaled_X_data[i : i + window_size])\n","    y.append(scaled_y_data[i + window_size][0])\n","\n","X = np.array(X)\n","y = np.array(y)\n","\n","test_size = int(len(X) * 0.1)\n","X_train, X_test = X[:-test_size], X[-test_size:]\n","y_train, y_test = y[:-test_size], y[-test_size:]\n","\n","# ==========================================\n","# 4. CNN-LSTM 하이브리드 모델 학습\n","# ==========================================\n","print(\">>> 5. AI 모델 구축 및 학습 시작...\")\n","model = Sequential()\n","num_features = len(feature_cols)\n","\n","model.add(Conv1D(filters=64, kernel_size=2, activation='relu', input_shape=(window_size, num_features)))\n","model.add(MaxPooling1D(pool_size=2))\n","model.add(LSTM(50, activation='relu', return_sequences=True))\n","model.add(Dropout(0.2))\n","model.add(LSTM(30, activation='relu'))\n","model.add(Dropout(0.2))\n","model.add(Dense(1))\n","\n","model.compile(optimizer=Adam(learning_rate=0.001), loss='mean_squared_error')\n","\n","callbacks = [\n","    EarlyStopping(monitor='val_loss', patience=15, restore_best_weights=True),\n","    ModelCheckpoint(filepath=\"./data/model/cnn_lstm_best.keras\", monitor='val_loss', save_best_only=True, verbose=0),\n","    ReduceLROnPlateau(monitor='val_loss', factor=0.5, patience=5, min_lr=1e-5, verbose=0)\n","]\n","\n","history = model.fit(X_train, y_train, validation_split=0.1, epochs=150, batch_size=32, callbacks=callbacks, verbose=1)\n","\n","# ==========================================\n","# 5. 실시간 \"내일의 등락률\" 예측\n","# ==========================================\n","print(\"\\n>>> 6. 실시간 예측 평가...\")\n","recent_7_days_scaled = scaled_X_data[-window_size:]\n","X_predict = np.expand_dims(recent_7_days_scaled, axis=0)\n","scaled_prediction = model.predict(X_predict, verbose=0)\n","final_prediction_percent = y_scaler.inverse_transform(scaled_prediction)[0][0]\n","\n","print(\"-\" * 50)\n","print(f\"기준 마지막 체결일자: {df.index[-1]}\")\n","print(f\"🎯 AI 예측 (내일의 글로벌 비트코인 등락률): {final_prediction_percent:.2f}%\")\n","if final_prediction_percent > 0:\n","    print(\"📈 방향 예측: 가격 상승 (Long)\")\n","else:\n","    print(\"📉 방향 예측: 가격 하락 (Short)\")\n","print(\"-\" * 50)\n","\n","# ==========================================\n","# 6. 테스트셋 결과 시각화\n","# ==========================================\n","y_pred_scaled = model.predict(X_test, verbose=0)\n","y_test_real = y_scaler.inverse_transform(y_test.reshape(-1, 1))\n","y_pred_real = y_scaler.inverse_transform(y_pred_scaled)\n","\n","plt.figure(figsize=(12, 6))\n","plt.plot(y_test_real, label='Real Global BTC Return (%)', color='red', alpha=0.6, marker='o', markersize=3)\n","plt.plot(y_pred_real, label='Predicted Return (%)', color='blue', linestyle='--', marker='x', markersize=3)\n","plt.axhline(0, color='black', linewidth=1)\n","plt.title('Global BTC Return Prediction on Test Data')\n","plt.xlabel('Days in Test Set')\n","plt.ylabel('Return (%)')\n","plt.legend()\n","plt.grid(True, alpha=0.3)\n","plt.tight_layout()\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"bKY8jtuHlEeP","executionInfo":{"status":"ok","timestamp":1783428022536,"user_tz":-540,"elapsed":40402,"user":{"displayName":"김김태하","userId":"14747959825441316805"}},"outputId":"7